<?xml version="1.0" encoding="UTF-8"?>
<record_update table="sys_db_object">
    <sys_db_object>
        <name>x_avnth_bearing_trend</name>
        <label>Bearing Trend</label>
        <is_extendable>false</is_extendable>
        <access>public</access>
        <sys_scope display_value="Avennorth">x_avnth</sys_scope>
        <comments>Historical score tracking. One record per dimension per assessment run.</comments>
    </sys_db_object>

    <sys_dictionary>
        <element>u_trend_id</element>
        <column_label>Trend ID</column_label>
        <internal_type>string</internal_type>
        <max_length>36</max_length>
        <unique>true</unique>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_assessment</element>
        <column_label>Assessment</column_label>
        <internal_type>reference</internal_type>
        <reference>x_avnth_bearing_assessment</reference>
        <mandatory>true</mandatory>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_dimension</element>
        <column_label>Dimension</column_label>
        <internal_type>string</internal_type>
        <max_length>40</max_length>
        <mandatory>true</mandatory>
        <comments>Dimension name or 'overall'</comments>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_score</element>
        <column_label>Score</column_label>
        <internal_type>integer</internal_type>
        <comments>Score at this point in time 0-100</comments>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_run_date</element>
        <column_label>Run Date</column_label>
        <internal_type>glide_date_time</internal_type>
        <mandatory>true</mandatory>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_delta_from_previous</element>
        <column_label>Delta From Previous</column_label>
        <internal_type>integer</internal_type>
        <default_value>0</default_value>
        <comments>Change from previous assessment (-100 to +100)</comments>
    </sys_dictionary>
</record_update>
