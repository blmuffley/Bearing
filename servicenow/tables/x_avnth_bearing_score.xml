<?xml version="1.0" encoding="UTF-8"?>
<record_update table="sys_db_object">
    <sys_db_object>
        <name>x_avnth_bearing_score</name>
        <label>Bearing Score</label>
        <is_extendable>false</is_extendable>
        <access>public</access>
        <sys_scope display_value="Avennorth">x_avnth</sys_scope>
        <comments>Per-dimension scores. Eight records per assessment run.</comments>
    </sys_db_object>

    <sys_dictionary>
        <element>u_score_id</element>
        <column_label>Score ID</column_label>
        <internal_type>string</internal_type>
        <max_length>36</max_length>
        <unique>true</unique>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_assessment</element>
        <column_label>Assessment</column_label>
        <internal_type>reference</internal_type>
        <reference>x_avnth_bearing_assessment</reference>
        <mandatory>true</mandatory>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_dimension</element>
        <column_label>Dimension</column_label>
        <internal_type>choice</internal_type>
        <max_length>40</max_length>
        <choice_list>completeness,accuracy,currency,relationships,csdm,classification,orphans,duplicates</choice_list>
        <mandatory>true</mandatory>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_score</element>
        <column_label>Score</column_label>
        <internal_type>integer</internal_type>
        <comments>Dimension score 0-100</comments>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_weight</element>
        <column_label>Weight</column_label>
        <internal_type>decimal</internal_type>
        <comments>Weight used in composite (0.05 - 0.20)</comments>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_checks_passed</element>
        <column_label>Checks Passed</column_label>
        <internal_type>integer</internal_type>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_checks_total</element>
        <column_label>Checks Total</column_label>
        <internal_type>integer</internal_type>
    </sys_dictionary>

    <sys_dictionary>
        <element>u_details</element>
        <column_label>Details</column_label>
        <internal_type>string</internal_type>
        <max_length>4000</max_length>
        <comments>Breakdown of what was checked</comments>
    </sys_dictionary>
</record_update>
